# ============================================================
# TEI Annotator webservice — environment configuration
# ============================================================
# Copy this file to .env and set at least one provider API key.
# Providers are enabled based on which keys are present.
# ============================================================

# ------------------------------------------------------------
# HuggingFace Inference Router (https://huggingface.co/settings/tokens)
# ------------------------------------------------------------
HF_TOKEN=

# Default model pre-selected in the UI (optional). Format: <provider>/<model>
# SELECTED_MODEL=hf/meta-llama/Llama-3.3-70B-Instruct:nscale

# ------------------------------------------------------------
# Google Gemini (https://aistudio.google.com/app/apikey)
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# OpenAI (https://platform.openai.com/api-keys)
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# Anthropic Claude (https://console.anthropic.com/settings/keys)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# KISSKI academic cloud (https://kisski.gwdg.de)
# ------------------------------------------------------------
KISSKI_API_KEY=
KISSKI_BASE_URL=https://chat-ai.academiccloud.de/v1

# ------------------------------------------------------------
# Optional: GLiNER model for a pre-detection pass before the LLM.
# Leave empty to disable.  Requires the [gliner] extra:
#   uv pip install -e ".[gliner,webservice]"
# Example:
#   GLINER_MODEL=numind/NuNER_Zero
# ------------------------------------------------------------
GLINER_MODEL=

# ------------------------------------------------------------
# General API access key. Set to require all callers to present
#   Authorization: Bearer <key>
# Returned by /api/config and injected into the browser automatically.
# Leave empty to disable enforcement (open access / local development).
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
# ------------------------------------------------------------
API_KEY=

# ------------------------------------------------------------
# Premium model key. Visitors who arrive via ?key=<secret> (or have it
# in sessionStorage) see the full model list and may call expensive models.
# The key is sent as X-Premium-Key on API calls; the server refuses premium
# models without it, so knowing only API_KEY is not sufficient.
# Leave empty to disable the premium tier (all models visible to everyone).
# Generate: python -c "import secrets; print(secrets.token_hex(24))"
# ------------------------------------------------------------
PREMIUM_TOKEN=

# ------------------------------------------------------------
# Server bind settings (used only when running via `python main.py`).
# When using uvicorn directly, pass --host / --port on the CLI.
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8099

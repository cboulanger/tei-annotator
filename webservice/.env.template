# ============================================================
# TEI Annotator webservice — environment configuration
# ============================================================
# Copy this file to .env and set HF_TOKEN.
# On HuggingFace Spaces, HF_TOKEN is injected automatically —
# you only need to set it when running locally.
# ============================================================

# ------------------------------------------------------------
# HuggingFace API token (https://huggingface.co/settings/tokens)
# ------------------------------------------------------------
HF_TOKEN=

# ------------------------------------------------------------
# Default model shown pre-selected in the UI dropdown.
# Must be one of the model IDs listed in webservice/main.py
# under _HF_MODELS.
# ------------------------------------------------------------
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct:nscale

# ------------------------------------------------------------
# Optional: GLiNER model for a pre-detection pass before the LLM.
# Leave empty to disable.  Requires the [gliner] extra:
#   uv pip install -e ".[gliner,webservice]"
# Example:
#   GLINER_MODEL=numind/NuNER_Zero
# ------------------------------------------------------------
GLINER_MODEL=

# ------------------------------------------------------------
# Server bind settings (used only when running via `python main.py`).
# When using uvicorn directly, pass --host / --port on the CLI.
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8099
